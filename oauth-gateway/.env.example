KVDB_BASE_URL=https://kvdb-api.example.com
KVDB_API_KEY=replace-with-read-only-kvdb-key
GATEWAY_JWT_SECRET=replace-with-32-byte-random-secret
OAUTH_TX_SECRET=replace-with-32-byte-random-secret
GATEWAY_COOKIE_NAME=df_oauth_token
ORIGIN_ZTA_TOKEN=replace-with-origin-zta-token
OAUTH_ISSUER_URL=https://api.dreamreflex.com
# OAUTH_DISCOVERY_URL=https://api.dreamreflex.com/.well-known/openid-configuration
OAUTH_CLIENT_ID=replace-with-oauth-client-id
OAUTH_CLIENT_SECRET=replace-with-oauth-client-secret
OAUTH_SCOPES=openid,email
OAUTH_CLIENT_AUTH_METHOD=client_secret_post
ALLOW_PRIVATE_ORIGIN_IPS=false
DOMAIN_CACHE_TTL_SECONDS=60
ORIGIN_CACHE_TTL_SECONDS=60
ACCESS_CACHE_TTL_SECONDS=30
OAUTH_DISCOVERY_CACHE_TTL_SECONDS=300
